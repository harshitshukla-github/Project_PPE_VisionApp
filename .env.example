# ============================================================================
# PPB Vision Module — Environment Variables
# Copy this file to .env and fill in your values.
# ============================================================================

# Roboflow — dataset download (get from app.roboflow.com/settings/api)
ROBOFLOW_API_KEY=rf_xxxxxxxxxxxxxxxx

# Kaggle — dataset download (get from kaggle.com/settings → API → Create New Token)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key
# Kaggle PPE dataset identifier (format: owner/dataset-name from kaggle.com/datasets/...)
KAGGLE_PPE_DATASET=owner/safety-helmet-reflective-jacket

# Google Gemini 2.5 Flash — hybrid explainer
GOOGLE_API_KEY=AIzaXxxxxxxxxxxxxxxxxxx

# Model Configuration
PPB_MODEL_NAME=yolo26l                   # options: yolo26n, yolo26s, yolo26m, yolo26l, yolo26x, yolo11n, yolo11s, yolo11m, yolo11l, yolo11x
PPB_CONFIDENCE_THRESHOLD=0.45            # minimum detection confidence (0.0 - 1.0)
PPB_IOU_THRESHOLD=0.50                   # NMS IoU threshold (YOLO11 only, YOLO26 is NMS-free)
PPB_DEVICE=0                             # GPU index (0, 1, ...) or "cpu"
PPB_IMG_SIZE=640                         # inference image size

# Experiment Tracking
MLFLOW_TRACKING_URI=http://localhost:5000

# Logging
LOG_LEVEL=INFO                           # DEBUG, INFO, WARNING, ERROR
