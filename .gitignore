# ==============================================================================
# PPB Vision Module — .gitignore
# ==============================================================================

# Environment
.env
.venv/
__pycache__/
*.pyc
*.pyo

# uv
.python-version

# Data (large files — download via script)
data/raw/
data/processed/
data/splits/

# Model weights (large files — track via MLflow or DVC)
models/*.pt
models/*.onnx
models/*.engine
models/exports/

# Training runs (auto-generated by ultralytics)
runs/

# Jupyter
.ipynb_checkpoints/
*.ipynb_metadata/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# MLflow
mlruns/

# Misc
*.log
*.tmp
dist/
build/
*.egg-info/
